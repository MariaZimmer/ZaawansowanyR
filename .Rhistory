oblicz_bmi <- function(waga, wzrost){
waga/wzrost^2
}
oblicz_bmi(55,167)
oblicz_bmi <- function(waga, wzrost){
waga/wzrost^2
}
oblicz_bmi(55,167)*100
oblicz_bmi <- function(waga, wzrost){
waga/wzrost^2
}
oblicz_bmi(55,167)*10000
tryCatch(
oblicz_dobre_bmi <- function(waga, wzrost){
waga/wzrost^2
},
error = function(e) {0},
message = function(m) {print("Nie wpisano prawidowych wartości liczbowych")}
)
oblicz_dobre_bmi(55, "2")
tryCatch(
oblicz_dobre_bmi <- function(waga, wzrost){
waga/wzrost^2
},
error = function(e) {0},
message = function(m) {print("Nie wpisano prawidowych wartości liczbowych")}
)
oblicz_dobre_bmi(55, "2")
oblicz_bmi <- function(waga, wzrost){
waga/wzrost^2*10000
}
oblicz_bmi(55,167)
oblicz_dobre_bmi(55, "2")
oblicz_bmi(55, "2")
oblicz_bmi <- function(waga, wzrost){
if(!is.numeric(waga)) stop("waga nie jest liczbą")
if(!is.numeric(wzrost)) stop("wzrost nie jest liczbą")
waga/wzrost^2*10000
}
oblicz_bmi(55,'2')
oblicz_bmi <- function(waga, wzrost){
if(!is.numeric(waga)) stop("waga nie jest liczbą")
if(!is.numeric(wzrost)) stop("wzrost nie jest liczbą")
waga/wzrost^2*10000
}
oblicz_bmi(55,"2")
oblicz_bmi <- function(waga, wzrost){
if(!is.numeric(waga)) stop("waga nie jest liczbą")
if(!is.numeric(wzrost)) stop("wzrost nie jest liczbą")
waga/wzrost^2*10000
}
oblicz_bmi(55,"2")
## Komunikaty
# Podstawowe funkcje do zgłaszania komunikatów:
# - `stop()` - zatrzymuje wykonanie, zgłasza błąd
# - `warning()` - ostrzega, ale kontynuuje wykonanie
# - `message()` - wyświetla komunikat informacyjny
oblicz_bmi <- function(waga, wzrost){
if(!is.numeric(waga)) stop("waga nie jest liczbą")
if(!is.numeric(wzrost)) stop("wzrost nie jest liczbą")
waga/wzrost^2*10000
}
oblicz_bmi(55,"2")
oblicz_bmi(55,2)
oblicz_bmi(55,167)
oblicz_bmi(55,"2")
oblicz_bmi <- function(waga, wzrost){
if(!is.numeric(waga)) stop("waga nie jest liczbą")
if(!is.numeric(wzrost)) stop("wzrost nie jest liczbą")    if(waga <= 0) warning("Waga powinna być dodatnia")
oblicz_bmi <- function(waga, wzrost){
if(!is.numeric(waga)) stop("waga nie jest liczbą")
if(!is.numeric(wzrost)) stop("wzrost nie jest liczbą")
if(waga <= 0) warning("Waga powinna być dodatnia")
if(wzrost <= 0) warning("Wzrost powinnien być dodatni")
waga/wzrost^2*10000
}
oblicz_bmi(55,-3)
oblicz_dobre_bmi <- function(waga, wzrost){
tryCatch(
expr = waga/wzrost^2*10000,
error = function(e) {0},
warning = function(w) {print("Nie wpisano prawidowych wartości liczbowych")}
)
}
oblicz_dobre_bmi(55, "2")
#Zadanie: Utwórz funkcje, która będzie zwracać współczynniki kierunkowe modelu regresji liniowej pomiędzy zmiennymi z wejściowej ramki danych.
wsp_korelacji <- function(x, y){
tryCatch(
expr = cor(x, y),
error = function(e) {
warning("abc")
NA
}
)
}
wsp_korelacji(1:10, "1:10")
#Zadanie: Utwórz funkcje, która będzie zwracać współczynniki kierunkowe modelu regresji liniowej pomiędzy zmiennymi z wejściowej ramki danych.
wsp_korelacji <- function(x, y){
tryCatch(
expr = cor(x, y),
error = function(e) {
warning(conditionMessage(e))
return(NA)
}
)
}
#condition - waring:(cond): 'y' must be numeric
wsp_korelacji(1:10, "1:10")
lapply(1:5, sqrt)
